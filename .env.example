# --- LLM ---
OPENAI_API_BASE=https://openrouter.ai/api/v1
OPENAI_API_KEY=your-key
# NOTE: the ":free" OpenRouter variants below are fine for local development and
# are NOT viable in production. Free tiers are capped around 20 requests/minute,
# and a single chat turn costs one chat call plus an embedding call per search —
# so they rate-limit long before this app is actually busy. Both models are
# admin-editable at /admin/settings, so a deployment can be moved off them
# without a redeploy; the embedding model is validated against the pgvector
# column's dimension when you save it.
CHAT_MODEL=deepseek/deepseek-v4-flash:free
EMBEDDING_MODEL=nvidia/llama-nemotron-embed-vl-1b-v2:free
CHUNK_SIZE=1000
CHUNK_OVERLAP=200

# --- Postgres (self-hosted via docker compose). DATABASE_URL is composed from these at runtime. ---
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=docwise
POSTGRES_PASSWORD=change-me
POSTGRES_DB=docwise

# --- Connection pool + pgvector (env-only: applied when the pool opens) ---
# pg-pool's own default is 10. One chat turn costs ~a dozen light queries plus a
# vector scan per search, so 10 saturates well below 100 concurrent users and
# every request queues behind someone else's search. Keep this under postgres's
# max_connections (docker-compose sets 200).
POSTGRES_POOL_MAX=30
POSTGRES_POOL_IDLE_TIMEOUT_MS=30000
POSTGRES_POOL_CONNECTION_TIMEOUT_MS=10000
# Kills a runaway statement rather than letting it hold a pool connection open.
POSTGRES_STATEMENT_TIMEOUT_MS=30000
# HNSW candidate list size. pgvector's default (40) is below the candidate pool
# this app asks for, which quietly made the index the recall bottleneck. Caps
# the admin-tunable retrieval.candidate_pool — raising that above this does nothing.
PGVECTOR_EF_SEARCH=120

# --- Capacity, retrieval, rate limits ---
# Every one of these is admin-editable at /admin/settings. The values here are
# only the fallback used when no override row exists.
RETRIEVAL_TOP_K=8
RETRIEVAL_MAX_PER_DOC=3
RETRIEVAL_CANDIDATE_POOL=60
# Attempts per provider call, including the first. Rate limits and 5xx are
# retried with jittered backoff; a bad model id is not.
LLM_MAX_RETRIES=3
# In-flight caps, process-wide. These queue work instead of letting a burst of
# users hit the provider as one spike and get the whole batch rate-limited.
EMBEDDING_CONCURRENCY=8
CHAT_CONCURRENCY=25
# Per signed-in user, sliding one-minute window. 0 disables.
RATE_LIMIT_PER_MINUTE=120
CHAT_RATE_LIMIT_PER_MINUTE=20
# Messages replayed to the model per turn (the full chat is still stored and
# shown), and the hard cap on messages kept per chat.
CHAT_HISTORY_WINDOW=20
CHAT_HISTORY_MAX_PERSISTED=200
# How long SIGTERM waits for in-flight generations before aborting them. Must
# stay below docker-compose's stop_grace_period (35s).
SHUTDOWN_DRAIN_TIMEOUT_MS=25000

# --- Microsoft Entra ID (Azure AD) ---
AZURE_CLIENT_ID=your-app-client-id
AZURE_TENANT_ID=your-tenant-id
AZURE_CLIENT_SECRET=your-client-secret
# Must be registered as a "Web" redirect URI on the app registration.
AZURE_REDIRECT_URI=http://localhost:5173/api/auth/callback

# --- App ---
FRONTEND_PORT=5173
# Where the backend redirects the browser back to after login.
FRONTEND_URL=http://localhost:5173
# Secret used to sign the short-lived PKCE/state cookie. Change in production.
SESSION_SECRET=change-me

# --- SharePoint List watcher (Phase A — uses the requesting user's delegated token). ---
SHAREPOINT_TENANT_HOSTNAME=saigontechnology0.sharepoint.com
SHAREPOINT_SITE_PATH=/QA/ISOTEAM
# Name of the registry list (case-insensitive). Every row in this list maps
# "List Name" → target SharePoint list URL; we sync each target.
SHAREPOINT_LIST_NAME="Document Distribution List"
# Days of slop for incremental sync. 0 = full sync each run.
SHAREPOINT_REGISTRY_INCREMENTAL_WINDOW_DAYS=0
