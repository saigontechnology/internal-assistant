OPENAI_API_BASE=https://openrouter.ai/api/v1
OPENAI_API_KEY=your-key
OPENAI_HOST_OVERRIDE=localhost:20128
CHAT_MODEL=deepseek/deepseek-v4-flash:free
EMBEDDING_MODEL=nvidia/llama-nemotron-embed-vl-1b-v2:free
# Steps per answer (retrieval rounds + 1 for the answer). Editable at /admin/settings.
CHAT_MAX_STEPS=6
CHUNK_SIZE=1000
CHUNK_OVERLAP=200

# Chat provider switch: `openai` (legacy — actually OpenRouter), `gemini`
# (Google Generative AI), or `opencode` (opencode.ai gateway).
# Only affects chat/generation; embeddings always use the OPENAI_* client above.
CHAT_PROVIDER=openai

# --- Gemini ---
# Required when CHAT_PROVIDER=gemini. Get a key at https://aistudio.google.com/app/apikey.
GOOGLE_GENERATIVE_AI_API_KEY=
GEMINI_CHAT_MODEL=gemini-2.5-flash-lite
GEMINI_CHAT_FALLBACK_MODEL=gemini-2.5-flash
GEMINI_CHAT_SECOND_FALLBACK_MODEL=gemini-3.1-flash

# --- OpenCode gateway (opencode.ai) ---
# Base URL points at the parent path; @ai-sdk/openai appends /chat/completions.
OPENCODE_API_BASE=https://opencode.ai/zen/go/v1
# Required when CHAT_PROVIDER=opencode.
OPENCODE_API_KEY=
# Fallback ladder, used only until an admin pins models at /admin/chat-model.
# Use the bare ids from `curl $OPENCODE_API_BASE/models` (e.g. "glm-5.2"),
# not the "<provider>/<model>" form — the gateway does not accept the latter.
OPENCODE_CHAT_MODEL=glm-5.2
OPENCODE_CHAT_FALLBACK_MODEL=kimi-k2.6
OPENCODE_CHAT_SECOND_FALLBACK_MODEL=minimax-m3

# Postgres (self-hosted via docker compose). DATABASE_URL is composed from these at runtime.
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=docwise
POSTGRES_PASSWORD=change-me
POSTGRES_DB=docwise

# Microsoft Entra ID (Azure AD)
AZURE_CLIENT_ID=your-app-client-id
AZURE_TENANT_ID=your-tenant-id
AZURE_CLIENT_SECRET=your-client-secret
# Must be registered as a "Web" redirect URI on the app registration.
AZURE_REDIRECT_URI=http://localhost:5173/api/auth/callback

FRONTEND_PORT=5173
# Where the backend redirects the browser back to after login.
FRONTEND_URL=http://localhost:5173
# Secret used to sign the short-lived PKCE/state cookie. Change in production.
SESSION_SECRET=change-me

# Comma-separated bootstrap admins for the /admin portal. Promoted to
# role='admin' at boot and on login. Promotion is one-way — removing an email
# here does not demote the user; do that from the portal.
ADMIN_EMAILS=

# SharePoint List watcher (Phase A — uses the requesting user's delegated token).
SHAREPOINT_TENANT_HOSTNAME=saigontechnology0.sharepoint.com
SHAREPOINT_SITE_PATH=/QA/ISOTEAM
# DEPRECATED as a sync input: distribution lists now live in the DB and are
# managed from /admin/links. This name is only used by the one-shot
# POST /api/admin/distribution-lists/import-registry migration endpoint.
SHAREPOINT_LIST_NAME="Document Distribution List"
# Days of slop for incremental sync. 0 = full sync each run.
SHAREPOINT_REGISTRY_INCREMENTAL_WINDOW_DAYS=0
