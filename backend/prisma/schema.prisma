// Prisma schema for the NestJS rewrite.
//
// Notes:
//  * Prisma 7 dropped `url` from the datasource block — connection details
//    come from prisma.config.ts (CLI) and the PrismaPg adapter (runtime).
//  * The `embedding` column is `halfvec(2048)` from pgvector, which Prisma
//    has no first-class type for. We declare it as `Unsupported(...)` so
//    introspection/migration leaves the column alone, and all reads/writes
//    against it go through `prisma.$queryRaw` (see EmbeddingsService).
//  * The HNSW index `embeddings_hnsw_idx` lives in a hand-written migration
//    (`migrations/20260609000001_pgvector_hnsw/`) because prisma migrate
//    can't express `USING hnsw (col halfvec_cosine_ops)`.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Resource {
  id            String      @id
  filename      String
  fileType      String      @map("file_type")
  source        String
  sharepointUrl String?     @map("sharepoint_url")
  createdAt     DateTime    @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt     DateTime    @default(now()) @map("updated_at") @db.Timestamp(6)
  embeddings    Embedding[]

  // SharePoint List watcher fields (added in migration 0002_watcher).
  // (sharepointListId, sharepointCode) is the stable identity for SP-sourced rows.
  // syncStatus tracks whether the file was actually ingested (`synced`) vs.
  // metadata-only (`pending_access` etc.) — see docs/sharepoint-list-watcher-plan.md §5.
  sharepointListId  String?   @map("sharepoint_list_id")
  sharepointCode    String?   @map("sharepoint_code")
  sharepointVersion String?   @map("sharepoint_version")
  // Set when the source list shows a newer Ver than what we have synced AND
  // the current caller couldn't resolve the new file. Embeddings still reflect
  // `sharepointVersion`; the row is flagged so the UI can warn users that
  // a fresher copy exists but nobody with access has refreshed it yet.
  sharepointPendingVersion String? @map("sharepoint_pending_version")
  sourceMetadata    Json?     @map("source_metadata")
  // Parsed from `sourceMetadata.date` (the free-text SP list "Date" column).
  // Set on every write that touches sourceMetadata; NULL when the value can't
  // be parsed. Column type is DATE — no time component.
  fileDate          DateTime? @map("file_date") @db.Date
  syncStatus        String    @default("synced") @map("sync_status")
  syncError         String?   @map("sync_error")
  lastSyncAttempt   DateTime? @map("last_sync_attempt") @db.Timestamp(6)

  @@unique([sharepointListId, sharepointCode], name: "sp_code_uk", map: "resources_sp_code_uk")
  @@index([syncStatus], map: "resources_sync_status_idx")
  @@map("resources")
}

model ChatHistory {
  id        String   @id
  // Stored as a JSON array of UIMessage. Validated against the AI SDK's
  // validateUIMessages on every load to make sure tool parts still match
  // the current tool set.
  messages  Json     @default("[]")
  // ID of the currently-active resumable stream (published in Redis via
  // resumable-stream). Non-null only while a chat is mid-generation; cleared
  // in the streamText onFinish callback and on explicit stop. A resuming
  // client GETs /api/chat/:id/stream, which looks this up to reconnect.
  activeStreamId String? @map("active_stream_id")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamp(6)

  @@map("chat_histories")
}

model WatcherState {
  listId        String    @id @map("list_id")
  lastRunAt     DateTime? @map("last_run_at") @db.Timestamp(6)
  lastStatus    String    @default("pending") @map("last_status")
  lastError     String?   @map("last_error")
  itemsSeen     Int       @default(0) @map("items_seen")
  itemsIngested Int       @default(0) @map("items_ingested")
  itemsUpdated  Int       @default(0) @map("items_updated")
  itemsSkipped  Int       @default(0) @map("items_skipped")
  itemsPending  Int       @default(0) @map("items_pending")
  itemsRemoved  Int       @default(0) @map("items_removed")
  itemsFailed   Int       @default(0) @map("items_failed")

  @@map("watcher_state")
}

model Embedding {
  id         String                       @id
  resourceId String                       @map("resource_id")
  content    String
  embedding  Unsupported("halfvec(2048)")
  metadata   Json?
  // onUpdate: NoAction matches the drizzle-emitted FK exactly so the baseline
  // migration is a no-op when applied to the existing dev DB.
  resource   Resource                     @relation(fields: [resourceId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "embeddings_resource_id_resources_id_fk")

  @@index([resourceId], map: "embeddings_resource_id_idx")
  @@map("embeddings")
}

model SyncAllowlist {
  email     String   @id
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamp(6)

  @@map("sync_allowlist")
}

model Session {
  id            String    @id
  homeAccountId String    @map("home_account_id")
  tokenCache    String    @map("token_cache")
  username      String?
  name          String?
  expiresAt     DateTime  @map("expires_at") @db.Timestamp(6)
  createdAt     DateTime  @default(now()) @map("created_at") @db.Timestamp(6)
  // Timestamp of the last successful MSAL acquireTokenSilent call for this
  // session. Refreshed by the SessionGuard hybrid check (see SessionService.get)
  // every AZURE_CHECK_INTERVAL_MS. Null on rows created before the check was
  // added — treated as "never checked" so the next request triggers one.
  lastAzureCheckAt DateTime? @map("last_azure_check_at") @db.Timestamp(6)

  @@map("sessions")
}

// Per-user metadata. Access control happens via JobProfile/JobProfileAccess —
// this row carries the user's normalized (jobTitle, department) tuple plus
// their personal resync cadence. `displayJobTitle` / `displayDepartment` keep
// the original AAD casing for UI; the lowercased fields are the join keys.
model UserPermission {
  email              String    @id
  jobTitle           String    @default("__unassigned__") @map("job_title")
  department         String    @default("__unassigned__") @map("department")
  displayJobTitle    String    @default("")              @map("display_job_title")
  displayDepartment  String    @default("")              @map("display_department")
  lastSync           DateTime? @map("last_sync") @db.Timestamp(6)
  lastError          String?   @map("last_error")
  // 'admin' | 'user'. Kept as a plain string rather than a PG enum so the
  // migration stays additive. Bootstrapped from ADMIN_EMAILS; thereafter
  // managed from the admin portal (promote-only from env — never demote).
  role               String    @default("user")
  // Deactivated users are rejected at login and on every subsequent request
  // (SessionGuard). Their session row is deleted on the first blocked request.
  isActive           Boolean   @default(true) @map("is_active")
  // Set when an admin manually pins (jobTitle, department). While true, the
  // Azure AD write path (UserPermissionService.upsertProfile) leaves the
  // normalized join keys alone so the override survives the weekly resync.
  profileOverride    Boolean   @default(false) @map("profile_override")
  createdAt          DateTime  @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt          DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamp(6)

  @@index([jobTitle, department])
  @@map("user_permissions")
}

// Per-job-profile cache. The (jobTitle, department) tuple is the access-control
// unit; `lastSync` is the authoritative resync cadence (NOT per-user). `syncing`
// is the in-flight lock that prevents two users with the same profile from
// scanning concurrently.
model JobProfile {
  jobTitle      String    @map("job_title")
  department    String    @map("department")
  lastSync      DateTime? @map("last_sync") @db.Timestamp(6)
  syncedByEmail String?   @map("synced_by_email")
  syncing       Boolean   @default(false)
  lastError     String?   @map("last_error")
  createdAt     DateTime  @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt     DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamp(6)

  @@id([jobTitle, department])
  @@map("job_profiles")
}

// (jobTitle, department) → sharepointCode allow-list. Rebuilt at the end of
// every successful scan (DELETE WHERE profile + bulk INSERT inside a tx).
model JobProfileAccess {
  jobTitle       String @map("job_title")
  department     String @map("department")
  sharepointCode String @map("sharepoint_code")

  @@id([jobTitle, department, sharepointCode])
  @@index([jobTitle, department])
  @@map("job_profile_access")
}

// One document-source list. Rows are owned by the admin portal: the DB is the
// source of truth for `displayName` / `note` / `listUrl`, and the watcher
// iterates these rows directly. `targetListId` is the dereferenced target of
// `listUrl` — null when the URL hasn't been (or can't be) resolved yet.
//
// `registryListId + registryItemId` are provenance only: they identify the row
// in the legacy "Document Distribution List" SharePoint registry that this row
// was imported from. Null for admin-created rows. The unique index still holds
// because Postgres treats NULLs as distinct.
model DistributionList {
  id              String   @id
  registryListId  String?  @map("registry_list_id")
  registryItemId  String?  @map("registry_item_id")
  displayName     String   @map("display_name")
  note            String?
  listUrl         String   @map("list_url")
  siteId          String?  @map("site_id")
  targetListId    String?  @map("target_list_id")
  // Disabled lists are skipped by the watcher and the job-profile scan. Their
  // resources stay in `resources` but get demoted to pending_access.
  enabled         Boolean  @default(true)
  createdByEmail  String?  @map("created_by_email")
  lastSeenAt      DateTime @default(now()) @map("last_seen_at") @db.Timestamp(6)
  lastSyncedAt    DateTime? @map("last_synced_at") @db.Timestamp(6)
  lastSyncStatus  String   @default("pending") @map("last_sync_status")
  lastSyncError   String?  @map("last_sync_error")
  itemsSynced     Int      @default(0) @map("items_synced")
  itemsPending    Int      @default(0) @map("items_pending")
  itemsFailed     Int      @default(0) @map("items_failed")
  itemsRemoved    Int      @default(0) @map("items_removed")
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt       DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamp(6)

  items                       DistributionListItem[]
  jobProfileDistributionLists JobProfileDistributionList[]

  @@unique([registryListId, registryItemId], name: "registry_uk", map: "distribution_lists_registry_uk")
  @@index([targetListId], map: "distribution_lists_target_idx")
  @@map("distribution_lists")
}

// Per-doc intent. Mirrors a subset of resources state so the Sidebar can
// render a list's roster of documents in one SELECT (no Graph round-trip).
// Caveat: this duplicates state that's authoritative on `resources`. Kept
// because the UI's "intent vs. outcome" view is much simpler this way.
model DistributionListItem {
  id                  String   @id
  distributionListId  String   @map("distribution_list_id")
  resourceId          String?  @map("resource_id")
  sharepointCode      String   @map("sharepoint_code")
  sharepointTitle     String   @default("") @map("sharepoint_title")
  sharepointVersion   String   @default("") @map("sharepoint_version")
  lastSeenAt          DateTime @default(now()) @map("last_seen_at") @db.Timestamp(6)
  syncStatus          String   @default("pending") @map("sync_status")
  syncError           String?  @map("sync_error")
  createdAt           DateTime @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt           DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamp(6)

  distributionList DistributionList @relation(fields: [distributionListId], references: [id], onDelete: Cascade, map: "dli_distribution_list_fk")

  @@unique([distributionListId, sharepointCode], name: "distribution_code_uk", map: "dli_distribution_code_uk")
  @@index([resourceId], map: "dli_resource_idx")
  @@index([syncStatus], map: "dli_status_idx")
  @@map("distribution_list_items")
}

// (jobTitle, department) ↔ distribution_list edge. Independent of
// job_profile_access (per-code); answers "which lists does this profile have
// any access to at all?" — used by the Sidebar's per-profile filtering.
model JobProfileDistributionList {
  jobTitle           String   @map("job_title")
  department         String   @map("department")
  distributionListId String   @map("distribution_list_id")
  firstSeenAt        DateTime @default(now()) @map("first_seen_at") @db.Timestamp(6)
  lastSeenAt         DateTime @default(now()) @map("last_seen_at") @db.Timestamp(6)

  distributionList DistributionList @relation(fields: [distributionListId], references: [id], onDelete: Cascade, map: "jpdl_distribution_list_fk")

  @@id([jobTitle, department, distributionListId])
  @@index([distributionListId], map: "jpdl_distribution_idx")
  @@map("job_profile_distribution_lists")
}

// Admin-editable runtime settings, keyed by a dotted string (e.g.
// "opencode.chat_model"). Only overrides live here: a missing key means the
// corresponding env default wins. See chat/chat-settings.service.ts.
model AppSetting {
  key            String   @id
  value          String
  updatedByEmail String?  @map("updated_by_email")
  updatedAt      DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamp(6)

  @@map("app_settings")
}
