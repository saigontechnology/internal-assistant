// Prisma schema for the NestJS rewrite.
//
// Notes:
//  * Prisma 7 dropped `url` from the datasource block — connection details
//    come from prisma.config.ts (CLI) and the PrismaPg adapter (runtime).
//  * The `embedding` column is `halfvec(2048)` from pgvector, which Prisma
//    has no first-class type for. We declare it as `Unsupported(...)` so
//    introspection/migration leaves the column alone, and all reads/writes
//    against it go through `prisma.$queryRaw` (see EmbeddingsService).
//  * The HNSW index `embeddings_hnsw_idx` lives in a hand-written migration
//    (`migrations/20260609000001_pgvector_hnsw/`) because prisma migrate
//    can't express `USING hnsw (col halfvec_cosine_ops)`.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Resource {
  id            String      @id
  filename      String
  fileType      String      @map("file_type")
  source        String
  sharepointUrl String?     @map("sharepoint_url")
  createdAt     DateTime    @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt     DateTime    @default(now()) @map("updated_at") @db.Timestamp(6)
  embeddings    Embedding[]

  // SharePoint List watcher fields (added in migration 0002_watcher).
  // (sharepointListId, sharepointCode) is the stable identity for SP-sourced rows.
  // syncStatus tracks whether the file was actually ingested (`synced`) vs.
  // metadata-only (`pending_access` etc.) — see docs/sharepoint-list-watcher-plan.md §5.
  sharepointListId  String?   @map("sharepoint_list_id")
  sharepointCode    String?   @map("sharepoint_code")
  sharepointVersion String?   @map("sharepoint_version")
  sourceMetadata    Json?     @map("source_metadata")
  syncStatus        String    @default("synced") @map("sync_status")
  syncError         String?   @map("sync_error")
  lastSyncAttempt   DateTime? @map("last_sync_attempt") @db.Timestamp(6)

  @@unique([sharepointListId, sharepointCode], name: "sp_code_uk", map: "resources_sp_code_uk")
  @@index([syncStatus], map: "resources_sync_status_idx")
  @@map("resources")
}

model WatcherState {
  listId        String    @id @map("list_id")
  lastRunAt     DateTime? @map("last_run_at") @db.Timestamp(6)
  lastStatus    String    @default("pending") @map("last_status")
  lastError     String?   @map("last_error")
  itemsSeen     Int       @default(0) @map("items_seen")
  itemsIngested Int       @default(0) @map("items_ingested")
  itemsUpdated  Int       @default(0) @map("items_updated")
  itemsSkipped  Int       @default(0) @map("items_skipped")
  itemsPending  Int       @default(0) @map("items_pending")
  itemsRemoved  Int       @default(0) @map("items_removed")
  itemsFailed   Int       @default(0) @map("items_failed")

  @@map("watcher_state")
}

model Embedding {
  id         String                       @id
  resourceId String                       @map("resource_id")
  content    String
  embedding  Unsupported("halfvec(2048)")
  metadata   Json?
  // onUpdate: NoAction matches the drizzle-emitted FK exactly so the baseline
  // migration is a no-op when applied to the existing dev DB.
  resource   Resource                     @relation(fields: [resourceId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "embeddings_resource_id_resources_id_fk")

  @@index([resourceId], map: "embeddings_resource_id_idx")
  @@map("embeddings")
}

model Session {
  id            String   @id
  homeAccountId String   @map("home_account_id")
  tokenCache    String   @map("token_cache")
  username      String?
  name          String?
  expiresAt     DateTime @map("expires_at") @db.Timestamp(6)
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamp(6)

  @@map("sessions")
}
