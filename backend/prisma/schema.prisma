// Prisma schema for the NestJS rewrite.
//
// Notes:
//  * Prisma 7 dropped `url` from the datasource block — connection details
//    come from prisma.config.ts (CLI) and the PrismaPg adapter (runtime).
//  * The `embedding` column is `halfvec(2048)` from pgvector, which Prisma
//    has no first-class type for. We declare it as `Unsupported(...)` so
//    introspection/migration leaves the column alone, and all reads/writes
//    against it go through `prisma.$queryRaw` (see EmbeddingsService).
//  * The HNSW index `embeddings_hnsw_idx` lives in a hand-written migration
//    (`migrations/20260609000001_pgvector_hnsw/`) because prisma migrate
//    can't express `USING hnsw (col halfvec_cosine_ops)`.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Resource {
  id            String      @id
  filename      String
  fileType      String      @map("file_type")
  source        String
  sharepointUrl String?     @map("sharepoint_url")
  createdAt     DateTime    @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt     DateTime    @default(now()) @map("updated_at") @db.Timestamp(6)
  embeddings    Embedding[]

  @@map("resources")
}

model Embedding {
  id         String                       @id
  resourceId String                       @map("resource_id")
  content    String
  embedding  Unsupported("halfvec(2048)")
  metadata   Json?
  // onUpdate: NoAction matches the drizzle-emitted FK exactly so the baseline
  // migration is a no-op when applied to the existing dev DB.
  resource   Resource                     @relation(fields: [resourceId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "embeddings_resource_id_resources_id_fk")

  @@index([resourceId], map: "embeddings_resource_id_idx")
  @@map("embeddings")
}

model Session {
  id            String   @id
  homeAccountId String   @map("home_account_id")
  tokenCache    String   @map("token_cache")
  username      String?
  name          String?
  expiresAt     DateTime @map("expires_at") @db.Timestamp(6)
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamp(6)

  @@map("sessions")
}
